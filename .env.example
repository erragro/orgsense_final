# Copy this file to .env and fill in all values before running docker compose
# Never commit .env to git

# ── Database ──────────────────────────────────────────────────
DB_PASSWORD=

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=

# ── Weaviate ──────────────────────────────────────────────────
WEAVIATE_API_KEY=

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET_KEY=

# ── Bootstrap admin (first-run only) ─────────────────────────
BOOTSTRAP_ADMIN_EMAIL=admin@yourdomain.com
BOOTSTRAP_ADMIN_PASSWORD=

# ── BI read-only DB user ──────────────────────────────────────
BI_DB_PASSWORD=

# ── LLM ───────────────────────────────────────────────────────
LLM_API_KEY=

# ── OAuth ─────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── PII encryption ────────────────────────────────────────────
PII_ENCRYPTION_KEY=

# ── SMTP ──────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Grafana ───────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=
